{
    "name": "webkul/zadarma",
    "description": "Integracao Zadarma (click-to-call, historico e gravacoes de chamadas) para o Krayin CRM.",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "krayin/laravel-contact": "^1.0",
        "krayin/laravel-core": "^1.0",
        "krayin/laravel-lead": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Webkul\\Zadarma\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\Zadarma\\Providers\\ZadarmaServiceProvider"
            ],
            "aliases": {}
        }
    },
    "minimum-stability": "dev"
}
